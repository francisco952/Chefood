<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MenuTextStyle">
        <item name="android:textSize">22dp</item>
    </style>
    <style name="CustomTextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <!-- Fondo -->
        <item name="boxBackgroundColor">#C7D3C2</item>
        <!-- Bordes redondeados -->
        <item name="boxCornerRadiusTopStart">15dp</item>
        <item name="boxCornerRadiusTopEnd">15dp</item>
        <item name="boxCornerRadiusBottomStart">15dp</item>
        <item name="boxCornerRadiusBottomEnd">15dp</item>
        <!-- Quitar borde visible -->
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <!-- Color del hint -->
        <item name="hintTextColor">#282828</item>
    </style>
    <style name="RoundedImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>
</resources>
