<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contentAddIngredient"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    >
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:padding="5dp"
        style="@style/CustomTextInputLayout">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCantidad"
            android:layout_width="match_parent"
            android:hint="Cantidad"
            android:layout_height="56dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:padding="5dp"
        style="@style/CustomTextInputLayout">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etIngredient"
            android:layout_width="match_parent"
            android:hint="Ingrediente"
            android:layout_height="56dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"/>
    </com.google.android.material.textfield.TextInputLayout>
    <ImageButton
        android:id="@+id/deleteItemIngredient"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_delete"
        android:background="@drawable/ic_background_bt"
        android:contentDescription="@string/bt_delete"
        app:tint="@color/trash" />
</LinearLayout>