<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_food"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="16dp"
    android:layout_margin="8dp">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">
    <FrameLayout
        android:id="@+id/imgFood"
        android:layout_width="match_parent"
        android:layout_height="215dp"
        android:background="@drawable/fondo_menu">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="top|end"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/favoriteFood"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_favorite"
                android:background="@drawable/ic_background_bt"
                android:contentDescription="@string/bt_favorite"
                app:tint="@color/favorite"
                android:scaleType="center"
                android:padding="8dp"/>
            <ImageButton
                android:id="@+id/deleteFood"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/ic_background_bt"
                android:contentDescription="@string/bt_delete"
                app:tint="@color/trash"
                android:scaleType="center"
                android:padding="8dp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="bottom|start"
            android:padding="8dp">
            <ImageButton
                android:id="@+id/viewFood"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_visibility"
                android:background="@drawable/ic_background_bt"
                android:contentDescription="@string/bt_view"
                app:tint="@color/view"
                android:padding="8dp"/>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        >
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:padding="5dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="start"/>
        <TextView
            android:id="@+id/txtCalories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textStyle="italic"
            android:gravity="center"/>
    </LinearLayout>
    <TextView
        android:id="@+id/txtDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:textSize="18sp"
        android:gravity="start"/>

</LinearLayout>
</androidx.cardview.widget.CardView>