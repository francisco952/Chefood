<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ModalFragment">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:id="@+id/imgModal"
            android:layout_width="0dp"
            android:layout_height="270dp"
            android:background="@drawable/fondo_menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageButton
                    android:id="@+id/closeModal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_close"
                    android:background="@drawable/ic_background_bt"
                    android:contentDescription="@string/bt_close"
                    android:scaleType="center"
                    android:gravity="start"
                    android:padding="4dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <ImageButton
                    android:id="@+id/favoriteModal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_favorite"
                    android:background="@drawable/ic_background_bt"
                    android:contentDescription="@string/bt_favorite"
                    android:padding="8dp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="bottom|start"
                android:padding="8dp">
                <TextView
                    android:id="@+id/headerModal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hola Mundo"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:gravity="start"
                    android:textColor="@color/white">
                </TextView>
            </LinearLayout>
        </FrameLayout>
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/imgModal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:id="@+id/head_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/contentInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    tools:itemCount="0"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ingredients"
                    android:padding="12dp"
                    android:textSize="20sp"
                    android:gravity="start"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    app:drawableStartCompat="@drawable/ic_stockpot"
                    app:drawableTint="@color/green"
                    android:drawablePadding="10dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/txt_ingredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    tools:itemCount="0"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/steps"
                    android:padding="12dp"
                    android:textSize="20sp"
                    android:gravity="start"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    app:drawableStartCompat="@drawable/ic_flatware"
                    app:drawableTint="@color/green"
                    android:drawablePadding="10dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/txt_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    tools:itemCount="0"/>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>