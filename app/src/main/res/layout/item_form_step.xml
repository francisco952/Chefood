<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contentAddStep"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal">
    <TextView
        android:id="@+id/numberAddStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="5"
        android:background="@drawable/ct_background"
        android:backgroundTint="@color/bg_step"
        android:padding="5dp"
        android:text="1"
        android:textSize="25sp"
        android:textColor="@color/step"
        android:gravity="center"
        android:textStyle="bold"/>
    <Space
        android:layout_width="15dp"
        android:layout_height="wrap_content"/>
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:padding="5dp"
        style="@style/CustomTextInputLayout">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etStep"
            android:layout_width="match_parent"
            android:hint="Paso de prepación"
            android:layout_height="70dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"/>
    </com.google.android.material.textfield.TextInputLayout>
    <ImageButton
        android:id="@+id/deleteItemStep"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_delete"
        android:background="@drawable/ic_background_bt"
        android:contentDescription="@string/bt_delete"
        app:tint="@color/trash" />
</LinearLayout>